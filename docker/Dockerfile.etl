FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONUNBUFFERED=1

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        gdal-bin \
        python3 \
        python3-gdal \
        python3-psycopg2 \
        postgresql-client \
        ca-certificates \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace

COPY app/ /workspace/app/
COPY sql/ /workspace/sql/

CMD ["python3", "/workspace/app/build_network.py"]